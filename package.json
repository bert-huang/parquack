{
  "name": "parquack",
  "version": "1.1.1",
  "private": true,
  "description": "Browser extension for browsing Parquet files via DuckDB-WASM.",
  "type": "module",
  "scripts": {
    "build": "node build.mjs --target=firefox && node build.mjs --target=chrome",
    "build:firefox": "node build.mjs --target=firefox",
    "build:chrome": "node build.mjs --target=chrome",
    "watch": "node build.mjs --watch --target=firefox",
    "watch:chrome": "node build.mjs --watch --target=chrome",
    "package:firefox": "node build.mjs --target=firefox --package",
    "package:chrome": "node build.mjs --target=chrome --package",
    "package": "npm run package:firefox && npm run package:chrome",
    "run:firefox": "web-ext run --source-dir=build/firefox --firefox=firefox",
    "run:chrome": "web-ext run --source-dir=build/chrome --target=chromium"
  },
  "dependencies": {
    "@codemirror/commands": "6.10.3",
    "@codemirror/lang-sql": "6.10.0",
    "@codemirror/theme-one-dark": "6.1.3",
    "@codemirror/view": "6.42.0",
    "@duckdb/duckdb-wasm": "1.32.0",
    "apache-arrow": "17.0.0",
    "codemirror": "6.0.2"
  },
  "devDependencies": {
    "@resvg/resvg-js": "2.6.2",
    "esbuild": "0.28.0",
    "web-ext": "10.1.0"
  }
}
